{
  "java.import.maven.enabled": true,
  "java.import.exclusions": [
    "**/node_modules/**",
    "**/target/**",
    "**/bin/**"
  ],
  "files.exclude": {
    "**/node_modules": true,
    "**/target": true,
    "**/bin": true,
    "**/playwright-report": true,
    "**/test-results": true,
    "**/cypress/screenshots": true,
    "**/cypress/videos": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/target": true,
    "**/bin": true,
    "**/test-results": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/target/**": true,
    "**/bin/**": true,
    "**/playwright-report/**": true,
    "**/test-results/**": true,
    "**/cypress/screenshots/**": true,
    "**/cypress/videos/**": true
  },
  "testing.automaticallyOpenPeekView": "failureInVisibleDocument"
}
